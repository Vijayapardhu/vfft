# ============================================================================
# VFFT — Velangi Free Fire Tournament — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and MUST NEVER be committed.
#
# NEXT_PUBLIC_* values are exposed to the browser (safe: Firebase web config &
# Cloudinary cloud name / unsigned preset are designed to be public).
# Values WITHOUT the NEXT_PUBLIC_ prefix are server-only (Cloud Functions).
# ============================================================================

# --- Public site URL (canonical origin for SEO: sitemap, robots, OG, JSON-LD) -
# Set this to your real production domain so canonical/OG URLs are correct.
# Falls back to https://vfft.vercel.app when unset.
NEXT_PUBLIC_SITE_URL=https://vfft.vercel.app

# --- Firebase Web App config (Project settings → Your apps → Web app) -------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Realtime Database URL (the live engine — auction, matchState, presence, etc.)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# --- Cloud Functions region (default us-central1) ---------------------------
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# --- Firebase Cloud Messaging (FCM web push) --------------------------------
# Project settings → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Firebase App Check (reCAPTCHA v3 site key) -----------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# --- Cloudinary (unsigned client uploads) -----------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Cloudinary server credentials (server routes ONLY — never client) ------
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase Admin SDK (server-authoritative Next.js routes on Vercel) ------
# Base64 of the service account JSON: Firebase console → Project settings →
# Service accounts → Generate new private key. Then:  base64 -w0 sa.json
# This is the SECRET that powers the auction/purse/results engine. Server-only.
FIREBASE_SERVICE_ACCOUNT_B64=

# --- Local development: use Firebase Emulator Suite (true/false) ------------
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# --- Cron secret for scheduled jobs (lineup reminders) ----------------------
# Protects /api/cron/lineup-reminders. Point any scheduler (Vercel Cron, or a
# free external cron hitting the URL every ~10 min) at that route with header:
#   Authorization: Bearer <CRON_SECRET>
# Leave blank to disable the auth check (e.g. local dev). Admins can always
# trigger reminders manually from the Matches page ("Notify Lineup").
CRON_SECRET=
